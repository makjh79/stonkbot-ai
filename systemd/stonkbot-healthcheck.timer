[Unit]
Description=Run StonkBOT healthcheck every 5 minutes during market hours
After=stonkbot-db-ready.target

[Timer]
# Every 5 minutes, 24x7. The healthcheck script itself can decide
# whether it's market hours and what to check.
OnCalendar=*:*:0/5
Persistent=true

[Install]
WantedBy=timers.target
